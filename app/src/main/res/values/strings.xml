    <string name="instruction_title">How to get Id and Token</string>
    <string name="instruction_step_1">1. Open the Rocket.Chat tokens page using the button below (use the web version).</string>
    <string name="instruction_step_2">2. Sign in. Enter your login in the “verter@student.21-school.ru” format.</string>
    <string name="instruction_step_3">3. In the empty field, enter any text and tap the blue “Add” button.</string>
    <string name="instruction_step_4">4. Enter your Rocket.Chat password to confirm.</string>
    <string name="instruction_step_5">5. Copy the full text from the popup with Token and user Id.</string>
    <string name="instruction_step_6">6. Paste this text into the field below.</string>
